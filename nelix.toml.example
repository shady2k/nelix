# Nelix executor registry. Copy to nelix.toml (gitignored) and fill in real values.
# Launch is config-driven; per-tool code is only the classifier ("driver").
#
# IMPORTANT — `command` must `exec` INTO the leaf CLI. nelix runs it under a bare PTY with
# no interactive job-control shell in front, so whatever you name here owns the terminal's
# FOREGROUND process group. Do NOT use a supervising wrapper that stays alive around the
# real CLI (`envconsul -- claude`, `vault exec -- ...`, any `foo -- bar` that fork+waits):
# the live parent keeps the foreground group, the CLI runs in the background, hits
# SIGTTIN/SIGTTOU on first terminal access and is STOPPED (ps STAT `T`). It then renders
# nothing and nelix only ever sees a blank screen. Such a wrapper works when YOU run it in
# a terminal (your shell hands over the foreground) but breaks here. Fix: fetch secrets,
# then `exec` the CLI so it replaces the wrapper and becomes the foreground leader:
#   #!/bin/bash
#   export API_KEY="$(vault kv get -field=key path/to/secret)"   # fetch, then...
#   exec my-agent-cli "$@"                                        # ...exec (no lingering parent)
[executors.example_cli]
command = "my-agent-cli"
args = ["--interactive"]
env = {}                 # extra env if needed; secrets via your own secret manager
# no cwd here: the working dir is per-session — passed to nelix_start (defaults to the
# orchestrator's own cwd), so one executor entry serves any project.
driver = "claude"        # which classifier to use
launcher = "local"       # MVP: only "local" is implemented ("auto"/"docker" are post-MVP)
# Recovery thresholds (optional; defaults shown). The prompt/mandate can override per session.
# max_idle_seconds = 600   # no meaningful progress for this long -> daemon escalates to you (0 = off)
# max_restarts     = 3     # consecutive auto-restarts (no progress) before Hermes escalates

# Retention (optional; defaults shown). Applied by the daemon/supervisor.
daemon_log_retain    = 10    # how many daemon-<ts>-<pid>.log files to keep (min 1)
session_retain       = 20    # how many session dirs to keep by count (0 = disable this rake)
session_max_age_days = 7     # also delete session dirs older than this (0 = disable this rake)

# Reaping: seconds between SIGTERM and SIGKILL when killing a stuck/orphaned executor
# process group (the daemon's own group-kill and startup orphan reconcile). Default 5.
kill_grace_seconds = 5

# Daemon log verbosity: debug | info | warning | error (default: info).
# Env NELIX_LOG_LEVEL overrides this. Audit records (decisions, delivered task) are always written.
log_level = "info"
