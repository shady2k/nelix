#!/usr/bin/env python3
"""One-shot waiter: long-poll the router /wait, print a tiny DOORBELL for the first real event, exit.

The wake rides the host's notify_on_complete stdout capture — a bounded, tail-truncating channel.
So the wake carries ONLY small triage metadata (session_id, seq, kind, requires_response, hung):
never the executor's screen_excerpt or its trust fence, which can be large enough to truncate the
actionable fields away. Hermes pulls the authoritative state — and the decision_id it answers
against — from nelix_status, an uncapped tool-result channel.

S1c-2 / H14: uses the ROUTER's orchestration /wait (owner_id + orchestration_id + vector cursor),
not the daemon's state-file /wait.
"""
import argparse, json, os, sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
import paths
from daemon.transport import Transport
from rpc_client import RpcClient

# Small, fixed-size triage fields only — never executor content. event_id is intentionally absent:
# decision identity comes from the nelix_status pull, not an opaque token the model must echo.
_DOORBELL_FIELDS = ("session_id", "seq", "kind", "requires_response", "hung")


def _discover():
    """Return a Transport for the router's public socket.
    S1c-2: no state-file fallback — the router is the authority.
    Supports NELIX_ROUTER_HOST/NELIX_ROUTER_PORT env override for testing."""
    import os as _os
    host = _os.environ.get("NELIX_ROUTER_HOST")
    port = _os.environ.get("NELIX_ROUTER_PORT")
    if host and port:
        return Transport.tcp(host, int(port), "")
    sock_path = str(paths.router_sock())
    return Transport.unix(sock_path)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--owner-id", dest="owner_id", required=True,
                    help="The owner this waiter speaks for")
    ap.add_argument("--orchestration-id", dest="orchestration_id", required=True,
                    help="The orchestration to wait on")
    ap.add_argument("--cursor", dest="cursor_token", default=None,
                    help="Opaque vector cursor token (empty = start from now)")
    args = ap.parse_args()

    try:
        transport = _discover()
    except (OSError, ValueError, KeyError) as e:
        print(json.dumps({"kind": "none"}, ensure_ascii=False))
        return 0

    client = RpcClient(transport, args.owner_id)

    try:
        # H14: Use the router's orchestration /wait.
        # Build params manually since RpcClient.wait() uses the daemon's shape.
        import urllib.parse
        params = {"owner_id": args.owner_id, "orchestration_id": args.orchestration_id}
        if args.cursor_token:
            params["cursor"] = args.cursor_token
        path = "/wait?" + urllib.parse.urlencode(params)
        _, body = client._call("GET", path, timeout=45)
    except (OSError, ConnectionError):
        print(json.dumps({"kind": "none"}, ensure_ascii=False))
        return 0

    if not isinstance(body, dict):
        print(json.dumps({"kind": "none"}, ensure_ascii=False))
        return 0

    if body.get("cursor_expired") or body.get("board_changed"):
        out = {"schema": "nelix.wake.v1", "status_required": True,
               "cursor_expired": body.get("cursor_expired", False),
               "board_changed": body.get("board_changed", False)}
        print(json.dumps(out, ensure_ascii=False))
        return 0

    evt = body.get("event")
    if evt is None:
        print(json.dumps({"kind": "none"}, ensure_ascii=False))
        return 0

    # Doorbell: tiny triage metadata only.
    out = {k: evt.get(k) for k in _DOORBELL_FIELDS}
    out["schema"] = "nelix.wake.v1"
    out["status_required"] = True
    if body.get("cursor"):
        out["cursor"] = body["cursor"]
    print(json.dumps(out, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    sys.exit(main())
