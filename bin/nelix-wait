#!/usr/bin/env python3
"""One-shot waiter: long-poll /wait, print a tiny DOORBELL for the first real event, exit.

The wake rides the host's notify_on_complete stdout capture — a bounded, tail-truncating channel.
So the wake carries ONLY small triage metadata (session_id, seq, kind, requires_response, hung):
never the executor's screen_excerpt or its trust fence, which can be large enough to truncate the
actionable fields away. Hermes pulls the authoritative state — and the decision_id it answers
against — from nelix_status, an uncapped tool-result channel."""
import argparse, http.client, json, os, sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from daemon.transport import Transport
from rpc_client import RpcClient

# Small, fixed-size triage fields only — never executor content. event_id is intentionally absent:
# decision identity comes from the nelix_status pull, not an opaque token the model must echo.
_DOORBELL_FIELDS = ("session_id", "seq", "kind", "requires_response", "hung")


def _discover(state_file):
    """Read the supervisor state file and return a Transport for the daemon endpoint."""
    with open(state_file) as f:
        return Transport.from_state(json.load(f))


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--state-file", dest="state_file", required=True,
                    help="Path to the supervisor state file (written by nelix on start)")
    ap.add_argument("--after", type=int, default=0)
    ap.add_argument("--session-id", dest="session_id", required=True,
                    help="Session to scope the wait to (REQUIRED: a session_id-less /wait is a "
                         "global wait that would deliver another session's event to this waiter)")
    args = ap.parse_args()
    if not args.session_id:
        # required=True rejects an absent flag; also refuse an empty value so the executor's waiter
        # can never fall back to a global (cross-session) wait. Mirrors the daemon's /wait guard.
        ap.error("--session-id must be non-empty")

    try:
        transport = _discover(args.state_file)
    except (OSError, ValueError, KeyError) as e:
        # State file missing, unreadable, or contains no valid transport — daemon gone or
        # not yet started. Exit cleanly so notify_on_complete wakes Hermes to reconcile.
        print(json.dumps({"kind": "none"}, ensure_ascii=False))
        return 0

    client = RpcClient(transport)
    after = args.after
    try:
        while True:
            # session_id is guaranteed present (required arg) — always scope the wait so a
            # cross-session event never wakes this waiter.
            path = f"/wait?after_seq={after}&session_id={args.session_id}"
            try:
                _st, body = client._call("GET", path, timeout=40)
                evt = body.get("event")
            except (OSError, ConnectionError, http.client.HTTPException):
                # Daemon gone/unreachable (e.g. torn down, restarting). Don't crash with a
                # traceback — exit cleanly so notify_on_complete wakes Hermes to reconcile
                # via nelix_status instead of surfacing a scary background failure.
                print(json.dumps({"kind": "none"}, ensure_ascii=False))
                return 0
            if evt is None:
                continue                     # timeout tick — re-issue
            # Doorbell: tiny triage metadata only. status_required tells Hermes to pull the
            # authoritative state via nelix_status (the wake is just "something happened on S").
            out = {k: evt.get(k) for k in _DOORBELL_FIELDS}
            out["schema"] = "nelix.wake.v1"
            out["status_required"] = True
            print(json.dumps(out, ensure_ascii=False))
            return 0
    except KeyboardInterrupt:
        print(json.dumps({"kind": "none"}, ensure_ascii=False))
        return 0


if __name__ == "__main__":
    sys.exit(main())
