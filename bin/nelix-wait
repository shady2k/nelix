#!/usr/bin/env python3
"""One-shot waiter: long-poll /wait, print the first real event as JSON, exit."""
import argparse, http.client, json, os, sys, urllib.error, urllib.request


def _read_token(token_file):
    """Token from the supervisor state file (--token-file) — the terminal tool
    that arms this waiter does NOT forward an `env` dict, so the token cannot be
    relied on in the environment. Falls back to NELIX_RPC_TOKEN for manual runs."""
    if token_file:
        with open(token_file) as f:
            return json.load(f)["token"]
    tok = os.environ.get("NELIX_RPC_TOKEN")
    if not tok:
        print("nelix-wait: no token (pass --token-file or set NELIX_RPC_TOKEN)",
              file=sys.stderr)
        sys.exit(2)
    return tok


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--base", default=os.environ.get("NELIX_RPC", "http://127.0.0.1:8765"))
    ap.add_argument("--after", type=int, default=0)
    ap.add_argument("--token-file", dest="token_file", default=None)
    ap.add_argument("--session-id", dest="session_id", default=None)
    args = ap.parse_args()
    token = _read_token(args.token_file)
    after = args.after
    try:
        while True:
            url = f"{args.base}/wait?after_seq={after}"
            if args.session_id:
                url += f"&session_id={args.session_id}"
            req = urllib.request.Request(url, headers={"X-Nelix-Token": token})
            try:
                with urllib.request.urlopen(req, timeout=40) as r:
                    evt = json.loads(r.read()).get("event")
            except (urllib.error.URLError, OSError, http.client.HTTPException):
                # Daemon gone/unreachable (e.g. torn down, restarting). Don't crash with a
                # traceback — exit cleanly so notify_on_complete wakes Hermes to reconcile
                # via nelix_status instead of surfacing a scary background failure.
                print(json.dumps({"kind": "none"}))
                return 0
            if evt is None:
                continue                     # timeout tick — re-issue
            # Self-sufficient wake: print the full actionable event so Hermes acts straight from
            # the notification — nelix_status/nelix_screen are fallback only. The raw TUI `summary`
            # (box-drawing chrome) is omitted; screen_excerpt carries the live ground truth.
            fields = ("seq", "event_id", "session_id", "executor", "kind", "hint", "hung",
                      "task_delivery", "requires_response", "screen_excerpt")
            print(json.dumps({k: evt.get(k) for k in fields}))
            return 0
    except KeyboardInterrupt:
        print(json.dumps({"kind": "none"}))
        return 0


if __name__ == "__main__":
    sys.exit(main())
