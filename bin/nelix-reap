#!/usr/bin/env python3
"""Out-of-band reaper. `--orphans` reaps a DEAD daemon's leftover child groups (refuses while
a live daemon holds the root); `<sid>` force-stops one live session via the daemon RPC."""
import argparse
import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
import paths                                   # noqa: E402
from generation_supervisor import GenerationSupervisor  # noqa: E402
from daemon import owner, reaper               # noqa: E402
from daemon.config import load_kill_grace_seconds  # noqa: E402


def _any_per_gen_live():
    """Check if ANY per-generation lock holder exists (including DB-unknown).
    H12: Per-dir handling is isolated — one failure doesn't end the scan.
    Must check the stored start_fingerprint, not just pid aliveness."""
    import json
    try:
        for d in paths.generations_root().iterdir():
            if not d.is_dir():
                continue
            try:
                lock_path = d / "daemon.lock"
                try:
                    meta = json.loads(lock_path.read_text())
                except Exception:
                    continue
                pid = meta.get("pid")
                fp = meta.get("start_fingerprint")
                if not pid:
                    continue
                # H12: Check that the pid is alive AND fingerprint matches.
                try:
                    os.kill(pid, 0)
                except OSError:
                    continue  # pid not alive — skip this dir
                if fp:
                    insp = reaper.ProcessInspector()
                    if insp.start_fingerprint(pid) != fp:
                        continue  # fingerprint mismatch — skip
                return True
            except Exception:
                # H12: Isolated per-dir — one bad dir must not abort the scan.
                continue
    except OSError:
        pass
    return False


def reap_orphans(inspector, killer, grace):
    if _any_per_gen_live():                    # never kill a live daemon's children
        return {"refused": "daemon_alive"}
    inspector = inspector or reaper.ProcessInspector()
    killer = killer or reaper.ProcessKiller()
    reaped = reaper.reconcile_orphans(paths.sessions_root(), daemon_pid=os.getpid(),
                                      daemon_fingerprint="<reap-cli>", grace=grace,
                                      inspector=inspector, killer=killer)
    return {"reaped": reaped}


def reap_sid(sid):
    """Graceful stop of ONE live session, through the daemon.

    /stop is owner-gated, and the reaper has no owner of its own, so it reads the session's
    DURABLE OWNER off disk and stops it AS that owner.
    """
    # S1c-2: find a live per-generation daemon.
    transport = None
    try:
        from nelix_store.store import Store
        store = Store(paths.nelix_root())
        try:
            gen_rows = store.list_generations()
        except Exception:
            gen_rows = []
        finally:
            store.close()
    except Exception:
        gen_rows = []

    for gr in gen_rows:
        try:
            sup = GenerationSupervisor(gr.generation_id, gr.build_id)
            ep = sup.endpoint()
            if ep is not None:
                transport = ep
                break
        except Exception:
            continue

    if not transport:
        return {"error": "no live daemon"}
    from rpc_client import RpcClient
    owner_id = owner.owner_of(paths.sessions_root() / sid)
    if owner_id is None:
        return {"error": "no owner record", "session_id": sid,
                "hint": "session unknown or its owner record is missing/malformed; "
                        "use --orphans to reap a dead daemon's leftover process groups"}
    return RpcClient(transport, owner_id).stop(sid)


def main(argv=None):
    ap = argparse.ArgumentParser()
    ap.add_argument("--orphans", action="store_true")
    ap.add_argument("sid", nargs="?")
    args = ap.parse_args(argv)
    if args.orphans:
        grace = load_kill_grace_seconds(str(paths.config_path()))
        print(json.dumps(reap_orphans(None, None, grace)))
    elif args.sid:
        print(json.dumps(reap_sid(args.sid)))
    else:
        ap.error("pass --orphans or a <sid>")
    return 0


if __name__ == "__main__":
    sys.exit(main())
