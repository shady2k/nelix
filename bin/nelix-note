#!/usr/bin/env python3
"""Source-checkout shim for the `nelix-note` console script. The CLI itself is
daemon/tools/note.py — installed, it is `<venv>/bin/nelix-note` and this file is not involved.
Kept so the daemon (and the suite) can name an executable in a repo that has not been installed;
daemon/hook_settings.py prefers the installed script and falls back to here."""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from daemon.tools.note import main           # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
