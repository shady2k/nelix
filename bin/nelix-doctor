#!/usr/bin/env python3
"""Read-only nelix operator status: daemon health, singleton-lock holder, live sessions,
detected strays (recorded children whose owner daemon is gone but child is alive), and the
Hermes-side wiring — whether each profile actually loads nelix.

No manifest_drift section: that check compared plugin.yaml's provides_tools against the tools
__init__.py registers, and both files left with the plugin (shady2k/hermes-nelix,
tests/test_plugin_manifest.py). It lived here only because the core repo root used to BE the
plugin root. hermes_wiring below still reports whether each profile loads nelix — that is a
property of the operator's Hermes install, which the core can see; the manifest's truthfulness
is a property of a repo the core no longer owns. An operator-facing drift check pointed at the
INSTALLED plugin dir would be a fair thing to add back [nelix-4el.1]."""
import json
import os
import sys
from pathlib import Path

import yaml                                    # ships with the tooling venv

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
import paths                                   # noqa: E402
import supervisor                              # noqa: E402
from daemon import reaper, singleton           # noqa: E402


def _scan_strays(inspector):
    strays = []
    try:
        dirs = [d for d in paths.sessions_root().iterdir() if d.is_dir()]
    except (FileNotFoundError, NotADirectoryError):
        return strays
    for sd in dirs:
        rec = reaper.read_child(sd)
        if rec is None or rec.get("sid") != sd.name:
            continue
        pid = rec.get("pid")
        owner_dead = (not inspector.is_alive(rec.get("daemon_pid"))) or \
            inspector.start_fingerprint(rec.get("daemon_pid")) != rec.get("daemon_fingerprint")
        if owner_dead and pid is not None and inspector.is_alive(pid) \
                and inspector.start_fingerprint(pid) == rec.get("child_fingerprint"):
            strays.append({"sid": rec["sid"], "pid": pid, "pgid": rec.get("pgid"),
                           "ppid": inspector.ppid(pid)})
    return strays


def _enabled_plugins(config_path):
    """The `plugins.enabled` list from a Hermes config.yaml, or [] when the file is missing,
    empty, malformed, or has no such list (tolerates `plugins:` being null)."""
    try:
        data = yaml.safe_load(Path(config_path).read_text())
    except (FileNotFoundError, NotADirectoryError, IsADirectoryError):
        return []
    except yaml.YAMLError:
        return []
    plugins = data.get("plugins") if isinstance(data, dict) else None
    enabled = plugins.get("enabled") if isinstance(plugins, dict) else None
    return [str(x) for x in enabled] if isinstance(enabled, list) else []


def hermes_home() -> Path:
    """Where Hermes keeps its profiles. Lives HERE, not in paths.py, and that is the point of
    nelix-9a4.7: paths.py is the CORE's layout and must not know a harness's name. This function
    is the last thing in the core that does, and it survives only because hermes_wiring below is
    explicitly a probe of the operator's Hermes install — a question the core answers ABOUT
    another program, not a place the core stores anything."""
    val = os.environ.get("HERMES_HOME", "").strip()
    if val:
        return Path(val)
    try:
        from hermes_constants import get_hermes_home
        return Path(get_hermes_home())
    except Exception:
        return Path(os.path.expanduser("~/.hermes"))


def _inspect_profile(name, profile_dir, config_path):
    """Wiring verdict for a single Hermes profile: is nelix enabled, installed, configured?"""
    enabled = "nelix" in _enabled_plugins(config_path)
    installed = (Path(profile_dir) / "plugins" / "nelix").is_dir()
    if enabled and installed:
        verdict, reason = "wired", None
    elif not enabled:
        verdict, reason = "not_wired", "nelix not in plugins.enabled"
    else:
        verdict, reason = "not_wired", "plugin dir missing"
    return {"name": name, "config": str(config_path), "dir": str(profile_dir),
            "nelix_enabled": enabled, "plugin_installed": installed,
            "verdict": verdict, "reason": reason}


def hermes_wiring(home=None):
    """Per-profile answer to 'does the profile the user launched actually load nelix?'. Inspects
    the root/default profile (<home>/config.yaml) plus every <home>/profiles/<name>/config.yaml.

    No `nelix_toml_present` per profile any more. It used to report
    <profile>/workspace/nelix/nelix.toml — the core's config back when the core's state lived
    inside Hermes' tree. The config is a property of $NELIX_HOME now, not of a Hermes profile,
    so a per-profile answer would be false for every profile forever. It is reported once, as
    `nelix_home` in collect(). (This line is why 'grep for the path STRINGS, not just the
    functions' matters: nothing here imported or called nelix_root — it hand-built the same
    path out of literals, invisible to a search for the accessor.)"""
    home = Path(home) if home is not None else hermes_home()
    profiles = [_inspect_profile("(root)", home, home / "config.yaml")]
    try:
        named = sorted(p for p in (home / "profiles").iterdir() if (p / "config.yaml").is_file())
    except (FileNotFoundError, NotADirectoryError):
        named = []
    for pdir in named:
        profiles.append(_inspect_profile(pdir.name, pdir, pdir / "config.yaml"))
    return {"home": str(home), "profiles": profiles}


def _disk_sessions():
    """Session ids present under the sessions root, sorted. Best-effort: a diagnostic must not
    raise because a directory it wanted to look at is missing."""
    try:
        return sorted(d.name for d in paths.sessions_root().iterdir() if d.is_dir())
    except OSError:
        return []


def collect(inspector=None):
    inspector = inspector or reaper.ProcessInspector()
    transport = supervisor.endpoint()
    holder = singleton.read_holder(paths.daemon_lock())
    # The session inventory comes from DISK, not from /status.
    #
    # /status is owner-filtered now (daemon/owner.py) and doctor has no owner: it diagnoses the
    # HOST, it does not drive sessions. The alternatives were both worse than reading the disk —
    # an operator/wildcard mode on /status would hand the whole board back to any caller that
    # asked for it, which is the exact bug owners exist to close, and guessing an owner would
    # report one harness's world as if it were the machine's.
    #
    # Reading the sessions root is strictly better for a diagnostic anyway: it is the same place
    # _scan_strays already looks, and it still answers when the daemon is DEAD — which is when
    # doctor is actually run. The meaning shifts from "sessions this daemon admits to" to
    # "session state on this host", which is the question being asked.
    sessions = _disk_sessions()
    if transport is not None and transport.kind == "tcp":
        base_url = f"http://{transport.host}:{transport.port}"
    elif transport is not None:
        base_url = str(transport.path)
    else:
        base_url = None
    return {"daemon": {"alive": transport is not None, "base": base_url},
            "nelix_home": {"root": str(paths.nelix_root()),
                           "config": str(paths.config_path()),
                           "config_present": paths.config_path().is_file()},
            "lock_holder": holder, "sessions": sessions,
            "strays": _scan_strays(inspector),
            "hermes_wiring": hermes_wiring()}


def main():
    print(json.dumps(collect(), indent=2))
    return 0


if __name__ == "__main__":
    sys.exit(main())
